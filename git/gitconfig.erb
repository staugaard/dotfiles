[user]
	name = Mick Staugaard
	email = <%= get_value('user.email', 'Your Email') %>

[alias]
	co = checkout
	latest = for-each-ref --sort=committerdate refs/heads --format='%(committerdate:short) %(refname:short)'

[color]
	diff = auto
	status = auto
	branch = auto

[core]
	excludesfile = <%= ENV['HOME'] %>/.gitignore
	editor = micro
	autocrlf = input

[apply]
	whitespace = nowarn

[format]
  pretty = %Cred%h%Creset %s %Cgreen(%cr) %C(blue)<%%an>%Creset%C(yellow)%d%Creset

[github]
	user = staugaard
	token = <%= get_value('github.token', 'GitHub API Token') %>

[push]
  default = simple

[branch]
  autosetuprebase = always

[commit]
	verbose = true

[init]
	defaultBranch = main

[url "git@github.com:vend/"]
	insteadOf = https://github.com/vend/
