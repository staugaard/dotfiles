{{- $name := promptStringOnce . "git.name" "Git name" "Mick Staugaard" -}}
{{- $email := promptStringOnce . "git.email" "Git email" "mick@staugaard.com" -}}
{{- $githubUser := promptStringOnce . "git.githubUser" "GitHub username" "staugaard" -}}
[data.git]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    githubUser = {{ $githubUser | quote }}
    privateURLRewrites = []
