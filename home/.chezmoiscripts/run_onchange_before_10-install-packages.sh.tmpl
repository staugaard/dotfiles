{{- if or (eq .chezmoi.os "darwin") (eq .chezmoi.os "linux") -}}
#!/bin/bash
set -euo pipefail

if [[ "{{ .chezmoi.os }}" == "darwin" ]]; then
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi

  if ! command -v brew >/dev/null 2>&1; then
    echo "Homebrew is required for macOS package installation, but brew is not available" >&2
    exit 1
  fi

  brew bundle --file=/dev/stdin <<'BREWFILE'
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
BREWFILE

  if command -v gh >/dev/null 2>&1; then
{{ range .packages.darwin.ghExtensions }}
    if gh extension list | grep -qE '(^|[[:space:]]){{ . }}([[:space:]]|$)'; then
      gh extension upgrade {{ . | quote }} || echo "Could not upgrade gh extension {{ . }}; continuing" >&2
    else
      gh extension install {{ . | quote }} || echo "Could not install gh extension {{ . }}; continuing" >&2
    fi
{{- end }}
  else
    echo "gh is not available; skipping GitHub CLI extension installation" >&2
  fi
elif [[ "{{ .chezmoi.os }}" == "linux" ]]; then
  if command -v apt-get >/dev/null 2>&1; then
    sudo apt-get update
    sudo apt-get install -y{{ range .packages.linux.apt }} {{ . | quote }}{{ end }}
  else
    echo "apt-get is required for Linux package installation; this repo only supports apt-based Linux" >&2
    exit 1
  fi
fi
{{- end }}
