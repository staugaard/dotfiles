#!/bin/bash
set -euo pipefail

if ! command -v cargo >/dev/null 2>&1; then
  echo "cargo is required for cargo tool installation, but it is not available" >&2
  exit 1
fi

{{ range .packages.cargo.crates -}}
if ! command -v {{ .command | quote }} >/dev/null 2>&1; then
  cargo install {{ .name | quote }}{{ range .args }} {{ . }}{{ end }}
fi
{{ end -}}
