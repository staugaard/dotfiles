{{- $nvmVersion := (gitHubLatestRelease "nvm-sh/nvm").TagName | trimPrefix "v" -}}
#!/bin/bash
set -euo pipefail

export NVM_DIR="$HOME/.nvm"
latest_version={{ $nvmVersion | quote }}

current=""
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  # shellcheck source=/dev/null
  . "$NVM_DIR/nvm.sh"
  current="$(nvm --version 2>/dev/null || true)"
fi

if [[ -n "$latest_version" && "$current" == "$latest_version" ]]; then
  exit 0
fi

curl -fsSL "https://raw.githubusercontent.com/nvm-sh/nvm/v${latest_version}/install.sh" | bash
