{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

font_dir="$HOME/.local/share/fonts/HackNerdFont"
mkdir -p "$font_dir"

{{- $fonts := .packages.linux.fonts }}
if{{ range $fonts.files }} [[ -f "$font_dir/{{ . }}" ]] &&{{ end }} true; then
  exit 0
fi

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT

archive="$tmp_dir/Hack.tar.xz"
curl -fsSL {{ $fonts.archiveUrl | quote }} -o "$archive"
echo {{ printf "%s  %s" $fonts.archiveSha256 "$archive" | quote }} | sha256sum -c -

{{ range $fonts.files -}}
tar -xJf "$archive" -C "$font_dir" {{ . | quote }}
{{ end -}}

if command -v fc-cache >/dev/null 2>&1; then
  fc-cache -f "$HOME/.local/share/fonts"
fi
{{- end }}
